# API Configuration
VITE_API_BASE_URL=https://api.yourdomain.com

# Shell Application URL (for development)
VITE_SHELL_URL=https://shell.yourdomain.com

# Development URLs (for local development)
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_SHELL_URL=http://localhost:4001

# Analytics
VITE_ANALYTICS_ID=your-analytics-id

# Feature Flags
VITE_ENABLE_PROFILE_EDITING=true
VITE_ENABLE_EXPERIENCE_MANAGEMENT=true